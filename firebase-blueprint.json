      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string", "enum": ["BD", "LOG"] },
        "federalTaxes": { "type": "number" },
        "icms": { "type": "number" },
        "directCost": { "type": "number" },
        "expenses": { "type": "number" },
        "minProfit": { "type": "number" }
      },
      "required": ["id", "ownerId", "federalTaxes", "icms", "directCost", "expenses", "minProfit"]
    },
    "CteRecord": {
      "title": "CteRecord",
      "description": "CTE record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "loadId": { "type": "string" },
        "cteNumber": { "type": "string" },
        "emissionDate": { "type": "string" },
        "customer": { "type": "string" },
        "origin": { "type": "string" },
        "destination": { "type": "string" },
