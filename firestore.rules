rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "diegociatos@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.token.email)) && get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == 'Administrador')
      );
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.token.email == userId;
    }

    // Basic validation
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Users
    match /users/{userId} {
      // Users can read their own profile, admins can read all
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      // Only admins can create new users (or the initial admin bootstrapping)
      allow create: if isAuthenticated() && (isAdmin() || (isOwner(userId) && request.resource.data.role == 'Cliente'));
      // Users can update their own profile (but not their role), admins can update any
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (isOwner(userId) && request.resource.data.role == resource.data.role)
      );
      allow delete: if isAdmin();
    }

    // Pricing Configs
    match /pricingConfigs/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // CTEs
    match /ctes/{cteId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role in ['Operacional', 'Financeiro', 'Gestor', 'Comercial']);
    }

    // Clients
    match /clients/{clientId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role in ['Comercial', 'Gestor', 'Financeiro']);
    }

    // Commercial Goals
    match /commercialGoals/{goalId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role in ['Gestor']);
    }

    // Commission Rules
    match /commissionRules/{ruleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Drivers
    match /drivers/{driverId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role in ['Operacional', 'Gestor', 'Financeiro', 'Comercial']);
    }

    // Vehicle Types
    match /vehicleTypes/{typeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Route Configs
    match /routeConfigs/{routeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Loads
    match /loads/{loadId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role in ['Operacional', 'Comercial', 'Gestor', 'Financeiro']);
    }

    // Bank Accounts
    match /bankAccounts/{accountId} {
      allow read: if isAuthenticated() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role in ['Financeiro', 'Gestor']);
      allow write: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role in ['Financeiro', 'Gestor']);
    }

    // DRE Categories
    match /dreCategories/{categoryId} {
      allow read: if isAuthenticated() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role in ['Financeiro', 'Gestor']);
      allow write: if isAdmin();
    }

    // Transactions
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role in ['Financeiro', 'Gestor']);
      allow write: if isAuthenticated() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role in ['Financeiro', 'Gestor']);
    }
  }
}
