rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.token.email)) && getUserData().role == role;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "diegociatos@gmail.com" ||
        request.auth.token.email == "ivaldo@ciatos.com.br" ||
        hasRole('Administrador')
      );
    }

    function isGestor() {
      return hasRole('Gestor');
    }

    function isFinanceiro() {
      return hasRole('Financeiro');
    }

    function isOperacional() {
      return hasRole('Operacional');
    }

    function isComercial() {
      return hasRole('Comercial');
    }

    function isCliente() {
      return hasRole('Cliente');
    }
    
    function isOwner(userId) {
      return isAuthenticated() && (request.auth.token.email == userId || request.auth.uid == userId);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Users
    match /users/{userId} {
      allow get: if true;
      allow list: if isAuthenticated() && (isAdmin() || isFinanceiro());
      allow create: if isAuthenticated() && (isAdmin() || isOwner(userId));
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (isOwner(userId) && request.resource.data.role == resource.data.role)
      );
      allow delete: if isAdmin();
    }

    // Pricing Configs
    match /pricingConfigs/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // CTEs
    match /ctes/{cteId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || isOperacional() || isFinanceiro() || isGestor() || isComercial());
    }

    // Clients
    match /clients/{clientId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || isComercial() || isGestor() || isFinanceiro());
    }

    // Commercial Goals
    match /commercialGoals/{goalId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isGestor();
    }

    // Commission Rules
    match /commissionRules/{ruleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Drivers
    match /drivers/{driverId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || isOperacional() || isGestor() || isFinanceiro() || isComercial());
    }

    // Vehicle Types
    match /vehicleTypes/{typeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Route Configs
    match /routeConfigs/{routeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Loads
    match /loads/{loadId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || isOperacional() || isComercial() || isGestor() || isFinanceiro());
    }

    // Bank Accounts
    match /bankAccounts/{accountId} {
      allow read: if isAuthenticated() && (isAdmin() || isFinanceiro() || isGestor() || isOperacional() || isComercial());
      allow write: if isAdmin() || isFinanceiro() || isGestor();
    }

    // DRE Categories
    match /dreCategories/{categoryId} {
      allow read: if isAuthenticated() && (isAdmin() || isFinanceiro() || isGestor() || isOperacional() || isComercial());
      allow write: if isAdmin();
    }

    // Transactions
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (isAdmin() || isFinanceiro() || isGestor() || isOperacional() || isComercial());
      allow write: if isAuthenticated() && (isAdmin() || isFinanceiro() || isGestor());
    }
  }
}
